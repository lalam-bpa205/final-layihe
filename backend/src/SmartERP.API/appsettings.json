{
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=smarterp;User=root;Password=SmartErp2026!;"
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini"
  },
  // Nümayiş datası: ilk işə düşmədə 12 aylıq real görünüşlü tarixçə yaradır.
  // Baza artıq doldurulubsa (Customers >= 5) təkrar işləmir.
